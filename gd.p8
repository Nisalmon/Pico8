pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- main --

function _init()
	score = 0
	player = {
		x = 20,
		y = 112,
		dy = 0,
		on_ground = true,
		alive = true,
	
		update = function(self)
			if btn(⬆️) and self.on_ground == true then
				self.dy = -4
				sfx(0)
			end
			
			self.dy += gravity
			self.y += self.dy
			
			if collisions_floor() then
				while collisions_floor() do
					self.y -= 1
				end
				self.y += 1
				self.dy = 0
				self.on_ground = true
			else
				self.on_ground = false
			end
		end,

		draw = function(self)
			spr(1, self.x, self.y)
		end,
	}
	spikes = {}
	floors = {}
	gravity = 0.2
	speed = 0.8
	timer = 0
	add_floor()
end

function _update60()
-- player mouvement --
	player:update()
	update_spikes()
	update_env()
	
	timer += 1
	if timer % 60 == 0 and player.alive == true then
		score += 1
	end
	random = rnd(100)
	if random >= 67 and timer % 15 == 0 then
		--spawn_spikes(128)
		generate_structure()
	end
	collisions_spikes()
	collisions_side_floors()
end

function _draw()
	cls(2)
	draw_env()
	player:draw()
	draw_spikes()
	print("y position:")
	print(player.y)
	print("on ground:")
	print(player.on_ground)
	print("dy:")
	print(player.dy)
	print("alive:")
	print(player.alive)
	print("score:")
	print(score)
end
-->8
-- environment --

function add_floor()
	for i=0, 18 do
		add(floors, {
			x = 8*i,
			y = 120
		})
	end
end

function add_one_floor()
	add(floors, {
		x = 8*18,
		y = 120
	})	
end

function update_env()
	for f in all(floors) do
		f.x -= speed
		if f.x < -8 then
			if f.y == 120 then
				add_one_floor()
			end
			del(floors, f)
		end
	end
end

function draw_env()
	for f in all(floors) do
		spr(2, f.x, f.y)
	end
end
-->8
-- spikes --

function spawn_spikes(x)
	add(spikes, {
		x = x,
		y = 112, 
	})
end

function update_spikes()
	for s in all(spikes) do
		s.x -= speed
		if s.x < -8 then
			del(spikes, s)
		end
	end
end

function draw_spikes()
	for s in all(spikes) do
		spr(3, s.x, s.y)
	end
end
-->8
-- collisions --


function collisions_spikes()
	for s in all(spikes) do
		if (player.x + 1 < s.x + 7 and
						player.x + 7 > s.x + 1 and
						player.y + 1 < s.y + 7 and
						player.y + 7 > s.y + 1) then
							player.alive = false
						end
	end
end

function collisions_side_floors()
	for s in all(floors) do
		if (player.x + 1 < s.x + 7 and
						player.x + 7 > s.x + 1 and
						player.y + 1 < s.y + 7 and
						player.y + 7 > s.y + 1) then
							player.alive = false
						end
	end
end


function collisions_floor()
	for f in all(floors) do
		if (player.x < f.x + 8 and
						player.x + 8 > f.x and
						player.y + 8 <= f.y + 2 and
						player.y + 8 >= f.y) then
							return true
						end
	end
	return false
end
-->8
-- structture generqtion --


function generate_structure()
	--struct = rnd(5)
	struct = 1
	if struct == 1 then
		add(floors, {
			x = 136,
			y = 112
		})
		add(floors, {
			x = 128,
			y = 112
		})	
	end
	
	
end
