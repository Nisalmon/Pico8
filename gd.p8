pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- main --

function _init()
	player = {
		x = 20,
		y = 112,
		dy = 0,
		on_ground = false,
		alive = true,
	
		update = function(self)
			if btn(⬆️) and flr(self.y) == 112 then
				self.dy = -2
			end
			self.dy += gravity
			self.y += self.dy
			if flr(self.y) > 112 then
				self.y = 112
			end
		end,

		draw = function(self)
			spr(1, self.x, self.y)
		end,
	}
	spikes = {}
	gravity = 0.2
	speed = 1
	timer = 0
end

function _update()
-- player mouvement --
	player:update()
	update_spikes()
	if btn(➡️) then
		player.x = player.x + speed
	end
	if btn(⬅️) then
		player.x = player.x - speed
	end
	
	timer += 1
	random = rnd(11)
	if random >= 5 and timer % 15 == 0 then
		spawn_spikes(128)
	end
	
end

function _draw()
	cls(1)
	draw_env()
	player:draw()
	draw_spikes()
end
-->8
-- environment --


function draw_env()
	pos = 0
	for i=0,15 do
		spr(2, pos, 120)
		pos+=8		
	end
end
-->8
-- spikes --

function spawn_spikes(x)
	add(spikes, {
		x = x,
		y = 112, 
	})
end

function update_spikes()
	for s in all(spikes) do
		s.x -= 2
		if s.x < -8 then
			del(spikes, s)
		end
	end
end

function draw_spikes()
	for s in all(spikes) do
		spr(3, s.x, s.y)
	end
end
